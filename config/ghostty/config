# Island-mac Ghostty — rose-pine-moon
# Generated by island-theme-set. Edit the template, not this file:
#   templates/ghostty-config.tpl

theme = Rose Pine
background = #191724

# Keep Option as a compose key so Option+L = @ etc. on a German layout.
macos-option-as-alt = false

font-family = JetBrainsMono Nerd Font
font-size = 16

# Clean titlebar: blank the title text and hide the folder proxy icon.
title = " "
macos-titlebar-proxy-icon = hidden

window-padding-x = 8
window-padding-y = 8

cursor-style = block
cursor-style-blink = false
window-theme = dark
background-opacity = 0.97
background-blur = true
confirm-close-surface = false

mouse-scroll-multiplier = 0.95
