#!/usr/bin/env bash
# island:summary=Update Homebrew and upgrade all installed apps (formulae + casks).

set -uo pipefail

if ! command -v brew >/dev/null 2>&1; then
  echo "Homebrew not found." >&2
  exit 1
fi

echo "==> brew update"
brew update

echo
echo "==> brew upgrade (formulae + casks)"
echo "    Casks that live in /Applications may ask for your password."
brew upgrade

echo
echo "==> brew cleanup"
brew cleanup

echo
echo "Up to date."
