#!/usr/bin/env bash
# island:summary=Render an image inline (used as the fzf preview in the wallpaper picker).
# island:args=<image>

set -uo pipefail

img="${1:-}"
[[ -f "$img" ]] || { echo "no image"; exit 0; }

# fzf exports the preview pane size; fall back to the terminal size.
cols="${FZF_PREVIEW_COLUMNS:-${COLUMNS:-60}}"
lines="${FZF_PREVIEW_LINES:-${LINES:-30}}"

if command -v chafa >/dev/null 2>&1; then
  # Outside a multiplexer: crisp kitty graphics (Ghostty native — fast and clean).
  # Inside tmux: symbol/half-block rendering instead. kitty-over-tmux-passthrough
  # in an fzf preview re-transmits the whole image every keypress (slow) and
  # ghosts/misaligns on redraw; symbols are plain colored text — instant and stable.
  if [[ -z "${TMUX:-}" ]]; then
    chafa -f kitty --animate off -s "${cols}x${lines}" "$img" 2>/dev/null && exit 0
  fi
  chafa -f symbols --animate off -s "${cols}x${lines}" "$img" 2>/dev/null && exit 0
fi

# Fallback: name + dimensions if chafa is unavailable.
basename "$img"
command -v sips >/dev/null 2>&1 && sips -g pixelWidth -g pixelHeight "$img" 2>/dev/null | tail -2
