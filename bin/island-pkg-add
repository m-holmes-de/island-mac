#!/bin/bash
# island:summary=Install a Homebrew package if missing and record it in the Brewfile (idempotent).
# island:args=[--cask] <packages...>

set -eEo pipefail

ISLAND_PATH="${ISLAND_PATH:-$HOME/.local/share/island-mac}"
BREWFILE="$ISLAND_PATH/Brewfile"

kind="brew"   # formula by default
if [[ "${1:-}" == "--cask" ]]; then
  kind="cask"
  shift
fi

if (( $# == 0 )); then
  echo "usage: island-pkg-add [--cask] <packages...>" >&2
  exit 1
fi

for pkg in "$@"; do
  # Record in the Brewfile if not already listed (so installs are reproducible)
  if ! grep -qE "^${kind} \"${pkg}\"" "$BREWFILE" 2>/dev/null; then
    echo "${kind} \"${pkg}\"" >> "$BREWFILE"
    echo "Added to Brewfile: ${kind} \"${pkg}\""
  fi

  # Install only if missing (brew is idempotent, but this keeps output quiet)
  if [[ "$kind" == "cask" ]]; then
    brew list --cask "$pkg" &>/dev/null || brew install --cask "$pkg"
  else
    brew list --formula "$pkg" &>/dev/null || brew install "$pkg"
  fi
done
